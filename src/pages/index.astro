---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <!-- borderless neural net canvas -->
      <div class="viz-wrapper">
        <canvas id="neural-canvas"></canvas>
      </div>

      <!-- always-dark mac terminal -->
      <div class="terminal">
        <!-- traffic lights -->
        <div class="terminal-bar">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
          <span class="terminal-bar-title">guest@tiss</span>
        </div>

        <!-- body -->
        <div class="terminal-body">
          <!-- command 1 -->
          <p class="line">
            <span class="ps1">~</span><span class="cmd">intro</span>
          </p>

          <!-- output: hero paragraph -->
          <pre
            class="output">
&gt; Booting: curiosity.exe
&gt; Warning: rabbit holes have no exit.
&gt; Log: ideas don't scare me. ignorance does.</pre>

          <div class="spacer"></div>

          <!-- command 2 -->
          <p class="line">
            <span class="ps1">~</span>
            <span class="cmd">links social --list</span>
          </p>

          <!-- output: social links -->
          {
            SOCIALS.length > 0 && (
              <div class="output-socials">
                <Socials />
              </div>
            )
          }

          <div class="spacer"></div>

          <!-- idle cursor -->
          <p class="line">
            <span class="ps1">~</span>
            <span class="blink-cursor"></span>
          </p>
        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Neural net: no border, no radius ──────────── */
  .viz-wrapper {
    position: relative;
    width: 100%;
    height: 200px;
    margin-bottom: 1.25rem;
    cursor: crosshair;
  }

  #neural-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .viz-label {
    position: absolute;
    bottom: 10px;
    left: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    pointer-events: none;
    z-index: 2;
  }

  .viz-label .rss-btn {
    pointer-events: all;
  }

  .viz-title {
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-foreground);
    text-shadow: 0 0 30px
      color-mix(in srgb, var(--color-accent) 60%, transparent);
  }

  /* ── Terminal (always dark) ────────────────────── */
  .terminal {
    background: #1a1b1e;
    border-radius: 10px;
    overflow: hidden;
    font-family:
      ui-monospace, "Cascadia Code", "Fira Mono", "JetBrains Mono", monospace;
    font-size: 0.82rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    margin-bottom: 0.5rem;
  }

  /* title bar */
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 11px 14px;
    background: #2a2b2e;
    border-bottom: 1px solid #3a3b3e;
    user-select: none;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-red {
    background: #ff5f57;
  }
  .dot-yellow {
    background: #ffbd2e;
  }
  .dot-green {
    background: #28c840;
  }

  .terminal-bar-title {
    margin-left: 8px;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: #888;
  }

  /* body */
  .terminal-body {
    padding: 16px 20px 18px;
    line-height: 1.6;
    color: #cdd6f4;
  }

  .line {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    margin: 0;
    white-space: pre-wrap;
  }

  .ps1 {
    color: #89b4fa;
    font-weight: 700;
    flex-shrink: 0;
  }

  .cmd {
    color: #a6e3a1;
  }

  .output {
    margin: 6px 0 0 0;
    padding-left: 1.25em;
    color: #cdd6f4;
    line-height: 1.8;
    white-space: pre-wrap;
    word-break: break-word;
    overflow-wrap: break-word;
    font-family: "Roboto Mono";
    font-size: inherit;
  }

  .spacer {
    height: 14px;
  }

  .output-socials {
    padding-left: 1.25em;
    margin-top: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* blinking block cursor */
  .blink-cursor {
    display: inline-block;
    width: 9px;
    height: 1.1em;
    background: #cdd6f4;
    vertical-align: middle;
    border-radius: 1px;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  /* ── Reduced motion ────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .viz-wrapper {
      display: none;
    }
    .blink-cursor {
      animation: none;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) sessionStorage.setItem("backUrl", "/");

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const canvas = document.getElementById(
      "neural-canvas"
    ) as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d")!;

    const resize = () => {
      const dpr = devicePixelRatio || 1;
      canvas.width = canvas.offsetWidth * dpr;
      canvas.height = canvas.offsetHeight * dpr;
      ctx.scale(dpr, dpr);
    };
    resize();
    window.addEventListener("resize", () => {
      resize();
      buildNet();
    });

    let mouseX = -1,
      mouseY = -1;
    const wrap = canvas.parentElement!;
    wrap.addEventListener("mousemove", (e: Event) => {
      const me = e as MouseEvent;
      const r = canvas.getBoundingClientRect();
      mouseX = me.clientX - r.left;
      mouseY = me.clientY - r.top;
    });
    wrap.addEventListener("mouseleave", () => {
      mouseX = -1;
      mouseY = -1;
    });

    const accent = () =>
      getComputedStyle(document.documentElement)
        .getPropertyValue("--color-accent")
        .trim() || "#0ea5e9";

    const W = () => canvas.offsetWidth;
    const H = () => canvas.offsetHeight;
    let rotX = 0.3,
      rotY = 0.0;

    const rot3 = (x: number, y: number, z: number) => {
      const cy = Math.cos(rotY),
        sy = Math.sin(rotY);
      const x1 = x * cy - z * sy,
        z1 = x * sy + z * cy;
      const cx = Math.cos(rotX),
        sx = Math.sin(rotX);
      const y1 = y * cx - z1 * sx,
        z2 = y * sx + z1 * cx;
      return { x: x1, y: y1, z: z2 };
    };

    const proj = (x: number, y: number, z: number) => {
      const fov = 380;
      const s = fov / (fov + z + 180);
      return { sx: W() / 2 + x * s, sy: H() / 2 + y * s, s };
    };

    interface N {
      x: number;
      y: number;
      z: number;
      layer: number;
      pulse: number;
    }
    interface E {
      a: number;
      b: number;
    }
    let nodes: N[] = [],
      edges: E[] = [];
    const LAYERS = [4, 5, 6, 7, 6, 5, 4];

    const buildNet = () => {
      nodes = [];
      edges = [];
      const gap = 100,
        totW = (LAYERS.length - 1) * gap;
      LAYERS.forEach((count, li) => {
        const lx = li * gap - totW / 2;
        for (let ni = 0; ni < count; ni++) {
          nodes.push({
            x: lx,
            y: (ni - (count - 1) / 2) * 42,
            z: Math.sin(li * 1.3 + ni * 0.9) * 25,
            layer: li,
            pulse: Math.random() * Math.PI * 2,
          });
        }
      });
      for (let i = 0; i < nodes.length; i++)
        for (let j = i + 1; j < nodes.length; j++)
          if (nodes[j].layer === nodes[i].layer + 1) edges.push({ a: i, b: j });
    };
    buildNet();

    let t = 0,
      hov = -1;

    const draw = () => {
      ctx.clearRect(0, 0, W(), H());
      t += 0.008;

      if (mouseX > 0) {
        rotY += ((mouseX / W() - 0.5) * 1.4 - rotY) * 0.04;
        rotX += ((mouseY / H() - 0.5) * 0.7 - rotX) * 0.04;
      } else {
        rotY += 0.0025;
      }

      const ps = nodes.map(n => {
        const r = rot3(n.x, n.y, n.z);
        return proj(r.x, r.y, r.z);
      });

      hov = -1;
      if (mouseX > 0) {
        let md = 26;
        ps.forEach((p, i) => {
          const d = Math.hypot(p.sx - mouseX, p.sy - mouseY);
          if (d < md) {
            md = d;
            hov = i;
          }
        });
      }

      const ac = accent();

      edges.forEach(e => {
        const pa = ps[e.a],
          pb = ps[e.b];
        const na = nodes[e.a],
          nb = nodes[e.b];
        const pulse =
          (Math.sin(
            t * (0.55 + (na.layer + nb.layer) * 0.04) +
              (na.pulse + nb.pulse) / 2
          ) +
            1) /
          2;
        const isHot = e.a === hov || e.b === hov;
        const rzAvg = (rot3(na.x, na.y, na.z).z + rot3(nb.x, nb.y, nb.z).z) / 2;
        const dA = Math.max(0, Math.min(1, (rzAvg + 220) / 280));

        ctx.beginPath();
        ctx.moveTo(pa.sx, pa.sy);
        ctx.lineTo(pb.sx, pb.sy);
        ctx.strokeStyle = ac;
        ctx.globalAlpha = (isHot ? 0.77 : 0.28 + pulse * 0.19) * dA;
        ctx.lineWidth = isHot ? 1.3 : 0.99;
        ctx.stroke();

        if (pulse > 0.65) {
          const tp = (pulse - 0.65) / 0.35;
          ctx.beginPath();
          ctx.arc(
            pa.sx + (pb.sx - pa.sx) * tp,
            pa.sy + (pb.sy - pa.sy) * tp,
            2.2 * pa.s,
            0,
            Math.PI * 2
          );
          ctx.fillStyle = ac;
          ctx.globalAlpha = 0.95 * dA;
          ctx.fill();
        }
      });

      nodes.forEach((n, i) => {
        const p = ps[i];
        const isHov = i === hov;
        const pulse = (Math.sin(t * 1.3 + n.pulse) + 1) / 2;
        const r = (3.5 + pulse * 2) * p.s;
        const dA = Math.max(
          0,
          Math.min(1, (rot3(n.x, n.y, n.z).z + 220) / 280)
        );

        if (isHov) {
          const g = ctx.createRadialGradient(
            p.sx,
            p.sy,
            r,
            p.sx,
            p.sy,
            r * 4.5
          );
          g.addColorStop(0, ac);
          g.addColorStop(1, "transparent");
          ctx.beginPath();
          ctx.arc(p.sx, p.sy, r * 4.5, 0, Math.PI * 2);
          ctx.fillStyle = g;
          ctx.globalAlpha = 0.22;
          ctx.fill();
        }

        ctx.beginPath();
        ctx.arc(p.sx, p.sy, isHov ? r * 1.7 : r, 0, Math.PI * 2);
        ctx.fillStyle = ac;
        ctx.globalAlpha = (isHov ? 1 : 0.45 + pulse * 0.35) * dA;
        ctx.fill();
      });

      ctx.globalAlpha = 1;
      requestAnimationFrame(draw);
    };

    draw();
  });
</script>
